# Šablon za .env fajl. Kopiraj u .env i popuni vrednosti.
# .env je gitignore-ovan — ne završava u repo-u.
#
# Gemini API key — nabavi na https://aistudio.google.com/apikey
# Koristi se u scripts/translate.js za prevod sadržaja na EN.
GEMINI_API_KEY=

# Model (opciono — default je "gemini-2.0-flash-thinking-exp")
# Druge opcije: "gemini-1.5-pro", "gemini-1.5-flash"
GEMINI_MODEL=gemini-2.5-pro
